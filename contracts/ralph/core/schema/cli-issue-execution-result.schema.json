{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/ralph/core/schema/cli-issue-execution-result.schema.json",
  "title": "RalphCliIssueExecutionResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "issue_id",
    "iteration",
    "outcome",
    "exit_code",
    "retryable",
    "handoff_required",
    "summary",
    "validation_results",
    "artifacts",
    "metrics"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "1.0"
    },
    "issue_id": {
      "type": "string",
      "minLength": 1
    },
    "iteration": {
      "type": "integer",
      "minimum": 1
    },
    "outcome": {
      "type": "string",
      "enum": [
        "success",
        "failure",
        "human_required"
      ]
    },
    "exit_code": {
      "type": "integer",
      "enum": [
        0,
        10,
        11,
        20,
        30
      ]
    },
    "failure_category": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "validation_failure",
        "implementation_error",
        "ambiguous_requirements",
        "transient_infrastructure",
        "tool_timeout",
        "tool_contract_violation",
        "unknown",
        null
      ]
    },
    "retryable": {
      "type": "boolean"
    },
    "retry_after_seconds": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "handoff_required": {
      "type": "boolean"
    },
    "handoff": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "assumptions_made",
        "questions_for_human",
        "impact_if_wrong",
        "proposed_revision_plan"
      ],
      "properties": {
        "assumptions_made": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "questions_for_human": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "impact_if_wrong": {
          "type": "string",
          "minLength": 1
        },
        "proposed_revision_plan": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "validation_results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lint",
        "typecheck",
        "test",
        "build"
      ],
      "properties": {
        "lint": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "skipped"
          ]
        },
        "typecheck": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "skipped"
          ]
        },
        "test": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "skipped"
          ]
        },
        "build": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "skipped"
          ]
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commit_hash",
        "pr_url",
        "files_changed"
      ],
      "properties": {
        "commit_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "pr_url": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^(https?://.*)?$"
        },
        "files_changed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "duration_ms",
        "tokens_used"
      ],
      "properties": {
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "tokens_used": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "success"
          }
        }
      },
      "then": {
        "properties": {
          "exit_code": {
            "const": 0
          },
          "failure_category": {
            "const": null
          },
          "handoff_required": {
            "const": false
          },
          "handoff": {
            "const": null
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "human_required"
          }
        }
      },
      "then": {
        "properties": {
          "exit_code": {
            "const": 20
          },
          "handoff_required": {
            "const": true
          },
          "failure_category": {
            "const": "ambiguous_requirements"
          },
          "handoff": {
            "type": "object"
          }
        },
        "required": [
          "handoff"
        ]
      }
    }
  ]
}
